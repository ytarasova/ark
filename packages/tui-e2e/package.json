{
  "name": "@ark/tui-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-rendered end-to-end test harness for the Ark TUI. Runs `ark tui` inside a real pty (via node-pty), pipes the output to xterm.js in a headless Chromium via Playwright, and asserts on screenshots + rendered text. Replaces the legacy tmux-in-tmux TuiDriver.",
  "scripts": {
    "test": "node node_modules/@playwright/test/cli.js test",
    "test:headed": "node node_modules/@playwright/test/cli.js test --headed",
    "test:debug": "node node_modules/@playwright/test/cli.js test --debug",
    "serve": "node --experimental-strip-types server.ts"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ws": "^8.5.12"
  },
  "trustedDependencies": [
    "@homebridge/node-pty-prebuilt-multiarch"
  ]
}
