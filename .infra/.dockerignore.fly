# .dockerignore used for the Fly arkd image build. Copied into the repo
# root as `.dockerignore` by scripts/build-fly-image.sh (trap restores the
# original on exit). `docker build` only honours a `.dockerignore` at the
# build context root, which is why we do not reference this file directly.
#
# KEEP the bun lockfile (`bun.lock`) and package.json in the context -- they
# drive the `bun install` step. Do NOT add them here.

# Dependencies (we run `bun install --production` inside the image).
node_modules/
*/node_modules/
packages/*/node_modules/

# VCS + build output.
.git/
.gitignore
dist/
packages/*/dist/
packages/web/dist/
ark-native
ark-darwin-*
ark-linux-*

# Editor / tooling caches.
.claude/
.workflow/
.vscode/
.idea/

# CI / test artefacts.
test-results/
playwright-report/
coverage/
*.log

# Local secrets / env files.
.env
.env.*

# Local ark state (in case a dev runs the build from a dir where `.ark`
# was accidentally dropped; the real `~/.ark` lives in $HOME, not the repo).
.ark/

# Desktop shell outputs.
packages/desktop/out/
packages/desktop/binaries/
packages/desktop/node_modules/

# Git worktrees created by ark's own session flow.
.worktrees/
worktrees/

# Local SQLite databases if any made it into the repo.
*.db
*.db-wal
*.db-shm

# OS junk.
.DS_Store
Thumbs.db
