# Local control-plane mode env. Source this (or copy to .env) before
# `bun packages/cli/index.ts server start --hosted`.
#
# Pairs with `.infra/docker-compose.dev.yaml` (Postgres on :15433,
# Redis on :6379). Designed for laptop dev -- NOT a production template.

# ── Profile + DB ───────────────────────────────────────────────────────────
# `control-plane` profile sets requireToken=true and blobBackend=s3 by
# default. We override both below to keep the laptop loop friction-free.
ARK_PROFILE=control-plane
DATABASE_URL=postgres://ark:ark@localhost:15433/ark?sslmode=disable
REDIS_URL=redis://localhost:6379

# ── Ports (shifted to avoid clashing with sibling worktree on defaults) ────
# Default conductor is 19100, web is 8420 -- a sibling `make dev` can hold
# those. This env pins the hosted stack to a distinct port set so CLI and
# web UI always talk to the hosted server, never to the local SQLite daemon.
#
# Two-process hosted dev setup:
#   Process 1: `bun packages/cli/index.ts server start --hosted --port 8421`
#              -- web UI + /api/rpc on :8421, conductor on :19101
#   Process 2: `bun packages/cli/index.ts server daemon start --port 19401`
#              -- WebSocket /ws on :19401 (for CLI commands)
#   Both processes read the same DATABASE_URL (Postgres) so they share state.
ARK_WEB_PORT=8421
ARK_CONDUCTOR_PORT=19101
ARK_ARKD_PORT=19301
ARK_SERVER_PORT=19401

# ── Storage ────────────────────────────────────────────────────────────────
# Override the control-plane profile's `s3` default; on a laptop we don't
# have S3 creds and don't want them -- file-backed blobs land in $ARK_DIR.
ARK_BLOB_BACKEND=local
# Hosted mode normally rejects LocalDiskBlobStore + FsSnapshotStore as
# pod-ephemeral and not multi-replica-safe. The dev override unblocks
# the laptop loop while a real S3SnapshotStore is still TODO. NEVER set
# this in a production / k8s deployment -- it silently disables tenant
# isolation guarantees for blobs and snapshots.
ARK_DEV_ALLOW_LOCAL_HOSTED_STORAGE=1

# ── Model routing ─────────────────────────────────────────────────────────
# Skip the runtime's `compat: ["bedrock"]` flag so the agent talks DIRECT to
# api.anthropic.com using your local ANTHROPIC_API_KEY, instead of routing
# through the TrueFoundry/Bedrock proxy. Affects:
#   1. resolve-stage.ts:102 (model slug picks `anthropic-direct` not `tf-bedrock`)
#   2. executors/claude-agent.ts:45 (skips setting ARK_COMPAT in launcher env)
# NEVER set in real deployments -- production wants centralized routing.
ARK_DEV_FORCE_DIRECT=1

# ── Secrets backend ────────────────────────────────────────────────────────
# Hosted mode picks AwsSecretsProvider (SSM Parameter Store) by default.
# Force the file-backed provider locally so secrets land in
# `${ARK_DIR}/secrets.json` (machine-key encrypted).
ARK_SECRETS_BACKEND=file

# ── Auth ───────────────────────────────────────────────────────────────────
# Disable token requirement for the laptop loop. Flip to `true` and mint
# a token via `ark token create` once the control plane boots.
ARK_AUTH_REQUIRE_TOKEN=false
ARK_DEFAULT_TENANT=default

# ── Observability ──────────────────────────────────────────────────────────
ARK_LOG_LEVEL=info

# ── LLM keys (placeholders; set real values before kicking off agents) ─────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
