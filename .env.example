# Copy to .env and adjust. See litellm/config.yaml and Makefile targets: litellm, claude.

# Must match between proxy and Claude (Bearer token to LiteLLM).
LITELLM_MASTER_KEY=sk-ark-litellm-local
ANTHROPIC_BASE_URL=http://127.0.0.1:4000
ANTHROPIC_AUTH_TOKEN=sk-ark-litellm-local

# Safer defaults behind non-Anthropic backends.
CLAUDE_CODE_DISABLE_1M_CONTEXT=1
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=70

# Upstream SambaNova key (used by litellm/config.yaml).
SAMBANOVA_API_KEY=

# OPENAI_API_KEY=
