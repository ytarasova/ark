# Copy to .env.dev and adjust. Makefile: make claude-tfy (TrueFoundry direct).
#
# NOTE: filename is .env.dev (not .env) on purpose. Bun auto-loads .env from
# cwd into process.env on boot, which would leave credentials in the
# long-lived daemon / arkd / conductor process memory. Agents get their
# credentials from the `ark secrets` store via StageSecretResolver, not from
# the shell env. .env.dev is only sourced by interactive make targets that
# need the values in the user's own shell.

# Makefile adds --continue and --dangerously-skip-permissions by default.
# Disable: CLAUDE_CONTINUE=0 and/or CLAUDE_SKIP_PERMISSIONS=0 make claude-tfy

# Safer defaults behind gateways.
CLAUDE_CODE_DISABLE_1M_CONTEXT=1
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=70

# TrueFoundry: bearer token for the gateway.
TRUEFOUNDRY_API_KEY=
# Gateway base URL (used as ANTHROPIC_BASE_URL if TRUEFOUNDRY_ANTHROPIC_BASE_URL is unset). Often includes /v1; check playground.
TRUEFOUNDRY_API_BASE=https://your-tfy-host/api/llm
# Optional: Messages API base if it differs from TRUEFOUNDRY_API_BASE. Doc: https://truefoundry.com/docs/ai-gateway/claude-code
#TRUEFOUNDRY_ANTHROPIC_BASE_URL=https://your-tfy-host/api/llm
# Optional TRUEFOUNDRY_ANTHROPIC_MODEL (default pi-agentic/global.anthropic.claude-opus-4-6-v1). Allowlisted Bedrock ids:
#   pi-agentic/global.anthropic.claude-opus-4-6-v1
#   pi-agentic/global.anthropic.claude-opus-4-5-20251101-v1-0
#   pi-agentic/global.anthropic.claude-sonnet-4-6
#   pi-agentic/us-anthropic-claude-sonnet-4-20250514-v1-0
#   pi-agentic/au-anthropic-claude-sonnet-4-5-20250929-v1-0
#   pi-agentic/global.anthropic.claude-haiku-4-5-20251001-v1-0
#   pi-agentic/openai-gpt-oss-120b-1-0
#   pi-agentic/us.meta.llama3-3-70b-instruct-v1-0
#   pi-agentic/meta.llama3-70b-instruct-v1-0
#   pi-agentic/deepseek.v3-v1-0
#TRUEFOUNDRY_ANTHROPIC_MODEL=pi-agentic/global.anthropic.claude-sonnet-4-6

# OPENAI_API_KEY=
