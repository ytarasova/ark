{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022"]
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "packages/web",
    "packages/e2e",
    "packages/desktop/tests",
    "**/__tests__/**",
    "packages/test-setup.ts"
  ]
}
