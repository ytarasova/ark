# Env for the control-plane e2e test suite. Sourced by
# `make test-e2e-control-plane`. Pairs with .infra/docker-compose.e2e.yaml
# (Postgres :15434, Redis :6380) and is fully isolated from .env.control-plane.
#
# Ports are shifted by +1 from the dev stack so the e2e suite can run while
# `make dev-stack` is also up.
#
# ARK_DIR is pinned to a per-run temp dir in the Makefile target; the value
# below is a default for ad-hoc runs.

# ── Profile + DB ──────────────────────────────────────────────────────────
ARK_PROFILE=control-plane
DATABASE_URL=postgres://ark:ark@localhost:15434/ark?sslmode=disable
REDIS_URL=redis://localhost:6380

# ── Ports (shifted +1 from .env.control-plane to avoid clashes) ───────────
ARK_WEB_PORT=8422
ARK_CONDUCTOR_PORT=19102
ARK_ARKD_PORT=19302
ARK_SERVER_PORT=19402
ARK_ARKD_URL=http://localhost:19302

# ── Storage (file-backed; same dev override as the control-plane env) ────
ARK_BLOB_BACKEND=local
ARK_DEV_ALLOW_LOCAL_HOSTED_STORAGE=1

# ── Model routing -- e2e never hits Anthropic; the stub agent calls /report
ARK_DEV_FORCE_DIRECT=1

# ── Secrets ──────────────────────────────────────────────────────────────
ARK_SECRETS_BACKEND=file

# ── Auth (token off so tests can hit /api/rpc unauthenticated) ───────────
ARK_AUTH_REQUIRE_TOKEN=false
ARK_DEFAULT_TENANT=default

# ── Observability ────────────────────────────────────────────────────────
ARK_LOG_LEVEL=warn
